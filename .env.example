# ─── Database (Neon PostgreSQL) ──────────────────────────────────────────────
# Get from: https://neon.tech → Create project → Connection string
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-at-least-32-chars"

# ─── Pusher Channels (Real-time) ──────────────────────────────────────────────
# Get from: https://pusher.com → Create App → Channels → App Keys
# Recommended cluster: ap2 (Mumbai) for South Asia
PUSHER_APP_ID="your_pusher_app_id"
PUSHER_KEY="your_pusher_key"
PUSHER_SECRET="your_pusher_secret"
PUSHER_CLUSTER="ap2"

# Client-side Pusher keys (must be prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_PUSHER_KEY="your_pusher_key"
NEXT_PUBLIC_PUSHER_CLUSTER="ap2"

# ─── App URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
