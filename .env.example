# ─── Frontend (Vite) ──────────────────────────────────────────────
# URL of your backend API (no trailing slash)
VITE_API_URL=https://omnipoll-api.onrender.com

# URL of your Socket.IO server (same as API)
VITE_SOCKET_URL=https://omnipoll-api.onrender.com

# ─── Backend (server/index.mjs) ───────────────────────────────────
# Port to run the server on
PORT=8787

# URL of your deployed frontend (for CORS)
FRONTEND_URL=https://omnipoll.vercel.app

# ─── Local Development ────────────────────────────────────────────
# For local dev, use:
# VITE_API_URL=http://localhost:8787
# VITE_SOCKET_URL=http://localhost:8787
