# ╔══════════════════════════════════════════════════════╗
# ║           OmniPoll 2.0 — Environment Variables       ║
# ║  Copy this file to .env (server) / .env.local (web)  ║
# ╚══════════════════════════════════════════════════════╝

# ── SERVER (apps/server/.env) ─────────────────────────

# Node environment: development | production | test
NODE_ENV=development

# Port the Hono server listens on (Render auto-sets this)
PORT=3001

# PostgreSQL connection string
# Local:   postgresql://omnipoll:omnipoll@localhost:5432/omnipoll
# Render:  copy from Render Postgres "Internal Database URL"
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/omnipoll

# Redis connection string
# Local:   redis://localhost:6379
# Render:  copy from Render Redis "Internal Redis URL"
REDIS_URL=redis://localhost:6379

# JWT secret — use a random 64-char string, NEVER share this
# Generate: openssl rand -hex 32
JWT_SECRET=replace_with_64_char_random_string_here_very_secret

# JWT expiry (access token)
JWT_EXPIRES_IN=15m

# JWT refresh token expiry
JWT_REFRESH_EXPIRES_IN=7d

# URL of your deployed frontend (for CORS)
# Local:      http://localhost:5173
# Production: https://omnipoll.vercel.app
FRONTEND_URL=http://localhost:5173

# ── STRIPE (optional — for billing) ──────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Stripe Price IDs (create in Stripe dashboard)
STRIPE_PRICE_STARTER_MONTHLY=price_starter_monthly_id
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly_id
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_enterprise_monthly_id

# ── OPENAI (optional — for AI moderation/analytics) ──
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key

# ── EMAIL / SMTP (optional — for notifications) ───────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@omnipoll.io

# ── SENTRY (optional — error tracking) ───────────────
# Get from: https://sentry.io → new project → DSN
SENTRY_DSN=https://your_key@sentry.io/project_id


# ── WEB (apps/web/.env.local) ─────────────────────────

# URL of your backend API server
# Local:      http://localhost:3001
# Production: https://omnipoll-api.onrender.com
VITE_API_URL=http://localhost:3001

# URL of your Socket.IO server (same as API usually)
VITE_SOCKET_URL=http://localhost:3001

# Stripe publishable key (safe to expose)
# Get from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_publishable_key

# PostHog analytics (optional)
# Get from: https://app.posthog.com
VITE_POSTHOG_KEY=phc_your_posthog_key

# Sentry DSN for frontend (optional)
VITE_SENTRY_DSN=https://your_key@sentry.io/project_id
