# ─── Neon PostgreSQL (neon.tech → your project → Connection String) ───────────
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# ─── JWT (any 32+ random characters) ─────────────────────────────────────────
JWT_SECRET=change_this_to_a_very_long_random_string_at_least_32_chars

# ─── Pusher Channels (pusher.com → App Keys) ─────────────────────────────────
PUSHER_APP_ID=your_pusher_app_id
PUSHER_KEY=your_pusher_key
PUSHER_SECRET=your_pusher_secret
PUSHER_CLUSTER=ap2

# ─── These are exposed to the browser (safe to expose) ───────────────────────
VITE_PUSHER_KEY=your_pusher_key
VITE_PUSHER_CLUSTER=ap2
VITE_API_BASE=/api

# ─── Optional: Email notifications (Resend.com) ──────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=noreply@omnipoll.app
