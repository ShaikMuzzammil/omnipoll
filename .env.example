# ─── Pusher (free real-time — get from pusher.com) ──────────────
VITE_PUSHER_KEY=your_pusher_key_here
VITE_PUSHER_CLUSTER=ap2

# Server-side Pusher (same app, all 4 needed)
PUSHER_APP_ID=your_pusher_app_id
PUSHER_KEY=your_pusher_key_here
PUSHER_SECRET=your_pusher_secret
PUSHER_CLUSTER=ap2

# ─── API URL (leave empty = same domain on Vercel) ──────────────
# On Vercel: leave VITE_API_URL blank (API is on same domain at /api/)
# For local dev: VITE_API_URL=http://localhost:3000
VITE_API_URL=
