// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ───────────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  avatar        String?
  plan          Plan      @default(FREE)
  bio           String?
  website       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  polls         Poll[]
  teams         TeamMember[]
  apiKeys       ApiKey[]
  notifications Notification[]
  responses     Response[]

  @@map("users")
}

enum Plan {
  FREE
  PRO
  TEAM
  ENTERPRISE
}

// ─── Poll ───────────────────────────────────────────────────────
model Poll {
  id            String      @id @default(cuid())
  ownerId       String
  owner         User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  teamId        String?
  team          Team?       @relation(fields: [teamId], references: [id])

  type          PollType
  question      String
  status        PollStatus  @default(DRAFT)
  joinCode      String      @unique

  // Option-based poll options (multiple_choice, ranking, bracket, etc.)
  options       Json?       // Array<{ text: string; imageUrl?: string; emoji?: string }>

  // Quiz-specific
  quizQuestions Json?       // Array<QuizQuestion>

  // Matrix
  matrixRows    String[]
  matrixColumns String[]

  // NPS
  lowLabel      String?
  highLabel     String?

  // Slider
  sliderMin     Int?
  sliderMax     Int?
  sliderStep    Int?
  leftLabel     String?
  rightLabel    String?

  // Fill-blank
  blankTemplate String?

  // Live matching
  matchLeft     String[]
  matchRight    String[]

  // Settings
  settings      Json?       // PollSettings

  // Scheduling
  scheduledAt   DateTime?
  closedAt      DateTime?
  duration      Int?        // seconds

  // Stats (denormalized for speed)
  participantCount Int      @default(0)
  responseCount    Int      @default(0)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  responses     Response[]
  analytics     PollAnalytics?

  @@map("polls")
}

enum PollType {
  multiple_choice
  word_cloud
  qa
  quiz
  rating
  ranking
  open_text
  image_choice
  nps
  matrix
  slider
  true_false
  fill_blank
  bracket
  prioritization
  heatmap
  emoji_reaction
  poll_series
  countdown_vote
  live_matching
}

enum PollStatus {
  DRAFT
  LIVE
  PAUSED
  CLOSED
  SCHEDULED
}

// ─── Response ───────────────────────────────────────────────────
model Response {
  id              String    @id @default(cuid())
  pollId          String
  poll            Poll      @relation(fields: [pollId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?     @relation(fields: [userId], references: [id])
  participantName String?
  answer          Json      // Flexible answer type
  deviceType      String?   // mobile, desktop, tablet
  country         String?
  responseTime    Int?      // milliseconds
  ipHash          String?   // hashed for privacy
  createdAt       DateTime  @default(now())

  @@map("responses")
}

// ─── Analytics ──────────────────────────────────────────────────
model PollAnalytics {
  id              String    @id @default(cuid())
  pollId          String    @unique
  poll            Poll      @relation(fields: [pollId], references: [id], onDelete: Cascade)
  responseRate    Float     @default(0)
  avgResponseTime Float     @default(0)
  sentimentScore  Float?
  npsScore        Float?
  peakParticipants Int      @default(0)
  computedAt      DateTime  @default(now())

  @@map("poll_analytics")
}

// ─── Team ───────────────────────────────────────────────────────
model Team {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  avatar      String?
  plan        Plan         @default(FREE)
  createdAt   DateTime     @default(now())

  members     TeamMember[]
  polls       Poll[]

  @@map("teams")
}

model TeamMember {
  id        String     @id @default(cuid())
  teamId    String
  team      Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      TeamRole   @default(MEMBER)
  joinedAt  DateTime   @default(now())

  @@unique([teamId, userId])
  @@map("team_members")
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// ─── API Keys ───────────────────────────────────────────────────
model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String    @default("Default")
  keyHash     String    @unique
  prefix      String
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@map("api_keys")
}

// ─── Notifications ──────────────────────────────────────────────
model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  read      Boolean   @default(false)
  data      Json?
  createdAt DateTime  @default(now())

  @@map("notifications")
}
