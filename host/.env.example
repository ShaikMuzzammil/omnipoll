# ─── Neon PostgreSQL (shared with learn app) ──────────────────────────────────
DATABASE_URL=postgresql://user:pass@host.neon.tech/neondb?sslmode=require

# ─── JWT (same secret as learn app — same database) ──────────────────────────
JWT_SECRET=your_32_plus_char_random_secret_here

# ─── Pusher ───────────────────────────────────────────────────────────────────
PUSHER_APP_ID=your_app_id
PUSHER_KEY=your_key
PUSHER_SECRET=your_secret
PUSHER_CLUSTER=ap2

# ─── Exposed to browser ───────────────────────────────────────────────────────
VITE_PUSHER_KEY=your_key
VITE_PUSHER_CLUSTER=ap2
VITE_API_BASE=/api
VITE_APP_NAME=OmniPoll Host
VITE_APP_ROLE=teacher

# ─── Student app URL (for QR codes and links) ─────────────────────────────────
VITE_STUDENT_APP_URL=https://omnipoll-learn.vercel.app

# ─── Optional: Email via Resend ───────────────────────────────────────────────
RESEND_API_KEY=re_your_key
FROM_EMAIL=noreply@omnipoll.app
