# ─── Neon PostgreSQL (SAME database as host app) ──────────────────────────────
DATABASE_URL=postgresql://user:pass@host.neon.tech/neondb?sslmode=require

# ─── JWT (SAME secret as host app) ───────────────────────────────────────────
JWT_SECRET=your_32_plus_char_random_secret_here

# ─── Pusher (SAME credentials as host app) ───────────────────────────────────
PUSHER_APP_ID=your_app_id
PUSHER_KEY=your_key
PUSHER_SECRET=your_secret
PUSHER_CLUSTER=ap2

# ─── Exposed to browser ───────────────────────────────────────────────────────
VITE_PUSHER_KEY=your_key
VITE_PUSHER_CLUSTER=ap2
VITE_API_BASE=/api
VITE_APP_NAME=OmniPoll Learn
VITE_APP_ROLE=student

# ─── Host app URL (for links back to teacher portal) ─────────────────────────
VITE_HOST_APP_URL=https://omnipoll-host.vercel.app

# ─── Optional: Email notifications via Resend ────────────────────────────────
RESEND_API_KEY=re_your_key
FROM_EMAIL=noreply@omnipoll.app
